# Copy this file to .env and fill in your values.
# Never commit .env files with real credentials.

# ── API base URL (without /api suffix) ─────────────────────────────────────────
#
# WEB / iOS SIMULATOR:
#   localhost works out of the box.
#
# ANDROID EMULATOR:
#   The app auto-rewrites localhost → 10.0.2.2 for API calls.
#   However, the Twitch OAuth flow opens a Chrome Custom Tab that also needs to
#   reach the backend. For auth to work on Android, use one of:
#
#   Option A (recommended): tunnel your local backend with ngrok/cloudflare:
#     ngrok http 5080
#     → EXPO_PUBLIC_API_URL=https://<random>.ngrok-free.app
#     Also set Twitch:RedirectUri in appsettings.json to match:
#       https://<random>.ngrok-free.app/api/v1/auth/twitch/callback
#     And register that URL in your Twitch app's OAuth redirect URIs.
#
#   Option B: use your machine's LAN IP (auth won't work — Twitch rejects
#     non-HTTPS non-localhost redirect URIs, but other features will work):
#     EXPO_PUBLIC_API_URL=http://192.168.1.42:5080
#
# PRODUCTION:
#   EXPO_PUBLIC_API_URL=https://your-deployed-api.example.com
#
EXPO_PUBLIC_API_URL=http://localhost:5080

# Twitch application Client ID (from dev.twitch.tv → Your Applications)
EXPO_PUBLIC_TWITCH_CLIENT_ID=your-twitch-client-id

# Expo project ID from expo.dev (required for EAS builds and OTA updates)
EXPO_PUBLIC_PROJECT_ID=your-expo-project-id
EAS_PROJECT_ID=your-eas-project-id

# Build variant: development | preview | production (default: production)
# APP_VARIANT=development
