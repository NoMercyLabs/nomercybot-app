{
  "expo": {
    "name": "NomercyBot",
    "slug": "nomercybot",
    "version": "1.0.0",
    "scheme": "nomercybot",
    "platforms": ["ios", "android", "web"],
    "orientation": "default",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0b0f"
    },
    "web": {
      "bundler": "metro",
      "output": "server",
      "favicon": "./assets/favicon.png"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "tv.nomercy.bot"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0b0f"
      },
      "package": "tv.nomercy.bot"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
